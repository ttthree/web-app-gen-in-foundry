{
  "name": "web-app-gen-in-foundry",
  "version": "0.1.0",
  "private": true,
  "description": "Scaffold for a Microsoft Foundry hosted-session Responses web app generator.",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm --filter @web-app-gen/contracts build && pnpm -r typecheck",
    "test": "vitest run",
    "ci": "pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
